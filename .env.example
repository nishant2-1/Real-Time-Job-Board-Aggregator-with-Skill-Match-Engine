APP_NAME=JobRadar API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_VERSION=1.0.0

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobrador
POSTGRES_USER=jobrador
POSTGRES_PASSWORD=jobrador

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

JWT_SECRET_KEY=replace-with-strong-access-secret
JWT_REFRESH_SECRET_KEY=replace-with-strong-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

CORS_ORIGINS=http://localhost:5173,http://localhost:3000
ADMIN_EMAILS=admin@jobrador.local

ADZUNA_APP_ID=
ADZUNA_APP_KEY=

RATE_LIMIT_DEFAULT=60/minute
SCRAPE_INTERVAL_MINUTES=30
SCRAPER_TIMEOUT_SECONDS=20

MAX_RESUME_UPLOAD_BYTES=5242880
MATCH_CACHE_TTL_SECONDS=3600

VITE_API_URL=http://localhost:8000
