# -----------------------------------------------------------------------------
# Database
# PostgreSQL connection string used by FastAPI, SQLAlchemy, Alembic, and Celery.
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+psycopg2://jobrador:jobrador@postgres:5432/jobrador

# -----------------------------------------------------------------------------
# Redis
# Redis URL used for Celery broker/result backend and short-lived caches.
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# -----------------------------------------------------------------------------
# JWT/Auth
# SECRET_KEY: long random string for signing JWTs.
# ALGORITHM: JWT signing algorithm.
# ACCESS_TOKEN_EXPIRE_MINUTES: access token lifetime in minutes.
# REFRESH_TOKEN_EXPIRE_DAYS: refresh token lifetime in days.
# -----------------------------------------------------------------------------
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# -----------------------------------------------------------------------------
# External API (Adzuna)
# Create your Adzuna app and paste credentials here.
# -----------------------------------------------------------------------------
ADZUNA_APP_ID=your-adzuna-app-id
ADZUNA_APP_KEY=your-adzuna-app-key

# -----------------------------------------------------------------------------
# CORS
# Comma-separated origins allowed to call the backend API from browsers.
# -----------------------------------------------------------------------------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Runtime/Logging
# LOG_LEVEL: DEBUG, INFO, WARNING, ERROR
# ENVIRONMENT: development, staging, production
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development

# -----------------------------------------------------------------------------
# Admin users
# Comma-separated list of admin emails.
# -----------------------------------------------------------------------------
ADMIN_EMAILS=admin@example.com

# -----------------------------------------------------------------------------
# Docker Hub publishing
# Used by GitHub Actions docker-build job for image tags and login.
# -----------------------------------------------------------------------------
DOCKER_HUB_USERNAME=your-dockerhub-username

# -----------------------------------------------------------------------------
# Frontend
# Vite base URL for backend API.
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Optional compose convenience variables (safe defaults).
# -----------------------------------------------------------------------------
POSTGRES_DB=jobrador
POSTGRES_USER=jobrador
POSTGRES_PASSWORD=jobrador
