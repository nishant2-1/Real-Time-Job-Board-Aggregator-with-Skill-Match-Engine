APP_NAME=JobRadar API
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# PostgreSQL
# Docker: use postgres
# Local machine: change host to localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=jobrador
POSTGRES_USER=jobrador
POSTGRES_PASSWORD=jobrador

# Redis
# Docker: use redis
# Local machine: change host to localhost
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# Celery
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/1

# Auth
# Generate strong values for production, for example:
# openssl rand -hex 32
JWT_SECRET_KEY=change-me-access-secret
JWT_REFRESH_SECRET_KEY=change-me-refresh-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Browser access
# Comma-separated list is supported by the backend config.
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional admin-only emails for protected scraper actions.
ADMIN_EMAILS=admin@example.com

# External provider credentials
# Adzuna is optional. If left blank, JobRadar still works using RemoteOK and Remotive.
# Get these from: https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# Direct ATS company feeds
# These are official public ATS board identifiers, not third-party aggregators.
# Examples:
# GREENHOUSE_BOARDS=stripe,airbnb
# LEVER_COMPANIES=netflix,figma
GREENHOUSE_BOARDS=
LEVER_COMPANIES=

# Runtime tuning
RATE_LIMIT_DEFAULT=60/minute
SCRAPE_INTERVAL_MINUTES=30
SCRAPER_TIMEOUT_SECONDS=20
MAX_RESUME_UPLOAD_BYTES=5242880
MATCH_CACHE_TTL_SECONDS=3600

# Frontend
VITE_API_URL=http://localhost:8000

# Docker Hub publishing
# Only needed if you extend CI to publish images.
DOCKER_HUB_USERNAME=
